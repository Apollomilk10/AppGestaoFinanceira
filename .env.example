# URL do CSV publicado da sua planilha do Google Sheets.
# Veja no README como gerar esse link.
VITE_SHEET_CSV_URL=

# URL do Google Apps Script (Web App) que grava novos gastos na planilha.
# Veja no README como gerar esse link.
VITE_APPS_SCRIPT_URL=

# URL do CSV publicado da aba "Categorias" (categorias/subcategorias
# customizadas criadas pelo app). Opcional — se não configurar, o app usa
# só as categorias padrão. Veja o README.
VITE_CATEGORIES_CSV_URL=

# Credenciais de acesso ao dashboard (login simples, suporta vários usuários).
# Formato: email1:senha1,email2:senha2
# Veja o README para entender os limites de segurança dessa abordagem.
VITE_APP_USERS=lucas@teste:12345,rafaela@teste:1234
